{
  "meta": {
    "stype": "url-params-viewer",
    "componentURL": "https://github.com/pandasuite/react-url-params-viewer/",
    "description": "Display PandaSuite launch URL parameters received through data binding and generate a matching deeplink preview."
  },
  "version": "2.0.0",
  "main": "",
  "system": {
    "localization": false
